<Window x:Class="PSZK_MarsRoverProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PSZK_MarsRoverProject"
        mc:Ignorable="d"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Title="Mars Rover Control Center" Height="550" Width="900"
        Background="#121212" WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.7*" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="#1a1a1c" x:Name="kamera">
            <Canvas x:Name="jatekter" Width="4000" Height="4000">
            </Canvas>
        </ScrollViewer>

        <Grid Grid.Column="0" Margin="-25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top">

                <StackPanel>
                    <Grid Width="250" Height="250" ClipToBounds="True">
                        <Image x:Name="SunImage" Source="pack://application:,,,/Images/sun.png" Margin="-65" Stretch="Uniform" Opacity="1"/>
                        <Image x:Name="MoonImage" Source="pack://application:,,,/Images/moon.png" Margin="-65" Stretch="Uniform" Opacity="0"/>
                    </Grid>

                    <TextBlock x:Name="idoszak" Text="Nappal" Foreground="Black" FontSize="30" FontFamily="Segoe UI Black" HorizontalAlignment="Center" Margin="0,-55,0,0"/>
                </StackPanel>

            </Viewbox>
        </Grid>


        <Border Grid.Column="1" Background="#252526" BorderBrush="#3e3e42" BorderThickness="2,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">

                    <TextBlock Text="ROVER ÁLLAPOT" Foreground="#ff9d00" FontSize="22" FontFamily="Segoe UI Black" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Separator Background="#3e3e42" Margin="0,0,0,20"/>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Szimuláció időtartama (óra):" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DurationInput" Text="60" FontSize="16" Padding="5" Background="#1e1e1e" Foreground="White" BorderBrush="#444" CaretBrush="White" VerticalContentAlignment="Center"/>
                            <Button x:Name="StartBtn" Content="INDÍTÁS" Grid.Column="1" Margin="8,0,0,0" Padding="12,5" Background="#C1440E" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="StartBtn_Click"/>
                        </Grid>
                    </StackPanel>

                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Hátralévő idő:" Foreground="#aaaaaa" Margin="0,0,10,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="hatralevoido" Text="00:00:00" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="1" Text="Marsi idő:" Foreground="#aaaaaa" Margin="0,0,10,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ido" Text="00:00:00" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Text="Pozíció:" Foreground="#aaaaaa" Margin="0,0,10,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPos" Text="X: 0 | Y: 0" Foreground="#4da6ff" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="3" Text="Cél:" Foreground="#aaaaaa" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="celPozicio" Text="X: 0 | Y: 0" Foreground="#ff4d4d" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <CheckBox x:Name="FollowRoverBox" IsChecked="True" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,25" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                        </CheckBox.LayoutTransform>
                        Rover kamera követés
                    </CheckBox>

                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Energiaszint" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Left"/>

                        <StackPanel x:Name="IsChargingindicator" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                            <TextBlock Text="⚡" Foreground="#4dff4d" FontSize="17" Margin="0,0,5,0"/>
                            <TextBlock Text="Töltés alatt..." Foreground="#4dff4d" FontSize="15" FontStyle="Italic" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="IsntChargingindicator" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                            <TextBlock Text="⚡" Foreground="red" FontSize="17" Margin="0,0,5,0"/>
                            <TextBlock Text="Fogyasztás alatt..." Foreground="Red" FontSize="15" FontStyle="Italic" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="EnergyBar" Value="100" Height="22" Margin="0,0,0,25" BorderThickness="0" Background="#1e1e1e">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop Color="#4dff4d" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>

                    <Expander x:Name="StatisztikaExpander" Header="ROVER STATISZTIKÁK" Foreground="White" FontWeight="Bold" Margin="0,0,0,25" BorderBrush="#3e3e42" BorderThickness="1" Background="#2d2d30">
                        <StackPanel Margin="10">
                            <TextBlock Text="Áramfogyasztás megoszlása" Foreground="#aaaaaa" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,15"/>

                            <Grid Width="140" Height="140" HorizontalAlignment="Center">
                                <Ellipse Fill="#3e3e42" />

                                <Path x:Name="SliceSpeed1" Fill="#007acc" />
                                <Path x:Name="SliceSpeed2" Fill="#4caf50" />
                                <Path x:Name="SliceSpeed3" Fill="#ffc107" />
                                <Path x:Name="SliceMining" Fill="#cff150" />
                                <Path x:Name="SliceStandby" Fill="#f44336" />
                                <Ellipse Width="90" Height="90" Fill="#2d2d30" />
                                <TextBlock x:Name="egysegnyiuzemanyag" Text="0 egység" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,15,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#007acc" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock  x:Name="egyblokk" Text="Lassú (1 blokk/fél óra) => 2 egységnyi energia" Foreground="White" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#4caf50" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="kettőblokk" Text="Normál (2 blokk/fél óra) => 8 egységnyi energia" Foreground="White" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#ffc107" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="háromblokk" Text="Gyors (3 blokk/fél óra) => 18 egységnyi energia" Foreground="White" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#cff150" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="miningenergy" Text="mining energy" Foreground="White" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#c150" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="standybyenergy" Text="standby energy" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Separator Background="#3e3e42" Margin="0,-10,0,20"/>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                                    <TextBlock  x:Name="asvanycounter" Text="Kibányászot ásványok:" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                                    <TextBlock  x:Name="osszlepes" Text="Megtett összlépés:" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="LogExpander" Header="Napló" Foreground="White" FontWeight="Bold" Margin="0,0,0,25" BorderBrush="#3e3e42" BorderThickness="1" Background="#2d2d30">
                        <ScrollViewer x:Name="LogScroll" Height="150" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LogPanel" Margin="5">
                                <TextBlock Text="A szimuláció elindult..." Foreground="#aaaaaa" FontSize="12" FontStyle="Italic" Margin="0,0,0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Expander>

                    <TextBlock Text="Sebesség / Gyorsítás" Foreground="#aaaaaa" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BoostButton1" Click="BoostButton1_Click" Width="60" Height="60" Margin="5" Background="#333337" BorderBrush="#555" BorderThickness="1">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Image Source="pack://application:,,,/Images/speedupicon1x.png" Width="40" Height="40"/>
                        </Button>
                        <Button x:Name="BoostButton2" Click="BoostButton2_Click" Width="60" Height="60" Margin="5" Background="#333337" BorderBrush="#555" BorderThickness="1">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Image Source="pack://application:,,,/Images/speedupicon2x.png" Width="40" Height="40"/>
                        </Button>
                        <Button x:Name="BoostButton3" Click="BoostButton3_Click" Width="60" Height="60" Margin="5" Background="#333337" BorderBrush="#555" BorderThickness="1">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Image Source="pack://application:,,,/Images/speedupicon3x.png" Width="40" Height="40"/>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>