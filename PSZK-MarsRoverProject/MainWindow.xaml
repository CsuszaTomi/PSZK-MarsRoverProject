<Window x:Class="PSZK_MarsRoverProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PSZK_MarsRoverProject"
        mc:Ignorable="d"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Title="Mars Rover Control Center" Height="550" Width="900"
        Background="#121212" WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.7*" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="#1a1a1c" x:Name="kamera">
            <Canvas x:Name="jatekter" Width="4000" Height="4000">
            </Canvas>
        </ScrollViewer>

        <Border Grid.Column="1" Background="#252526" BorderBrush="#3e3e42" BorderThickness="2,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">

                    <TextBlock Text="ROVER ÁLLAPOT" Foreground="#ff9d00" FontSize="22" FontFamily="Segoe UI Black" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Separator Background="#3e3e42" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Küldetés ideje:" Foreground="#aaaaaa" FontSize="14" Margin="0,0,10,10"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ido" Text="00:00:00" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Jelenlegi pozíció:" Foreground="#aaaaaa" FontSize="14" Margin="0,0,10,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPos" Text="X: 0 | Y: 0" Foreground="#4da6ff" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cél koordináta:" Foreground="#aaaaaa" FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="celPozicio" Text="X: 0 | Y: 0" Foreground="#ff4d4d" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <CheckBox x:Name="FollowRoverBox" IsChecked="False" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,25" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                        </CheckBox.LayoutTransform>
                        Rover kamera követés
                    </CheckBox>

                    <TextBlock Text="Energiaszint" Foreground="#aaaaaa" FontSize="14" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="EnergyBar" Value="100" Height="22" Margin="0,0,0,25" BorderThickness="0" Background="#1e1e1e">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#ff4d4d" Offset="0"/>
                                <GradientStop Color="#ffb84d" Offset="0.5"/>
                                <GradientStop Color="#4dff4d" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>

                    <Expander x:Name="StatisztikaExpander" Header="ROVER STATISZTIKÁK" Foreground="White" FontWeight="Bold" Margin="0,0,0,25" BorderBrush="#3e3e42" BorderThickness="1" Background="#2d2d30">
                        <StackPanel Margin="10">
                            <TextBlock Text="Áramfogyasztás megoszlása" Foreground="#aaaaaa" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,15"/>

                            <Grid Width="140" Height="140" HorizontalAlignment="Center">
                                <Ellipse Fill="#007acc" />

                                <Path Fill="#4caf50" Data="M 70,70 L 70,0 A 70,70 0 0,1 135,45 Z" />

                                <Path Fill="#ffc107" Data="M 70,70 L 135,45 A 70,70 0 0,1 125,115 Z" />

                                <Ellipse Width="90" Height="90" Fill="#2d2d30" />
                                <TextBlock x:Name="egysegnyiüzemanyag" Text="100 W" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,15,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#007acc" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock Text="Meghajtás (Motorok)" Foreground="White" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#4caf50" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock Text="Tudományos műszerek" Foreground="White" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                                    <Rectangle Width="12" Height="12" Fill="#ffc107" RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                                    <TextBlock Text="Kommunikáció (Föld)" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <TextBlock Text="Sebesség / Gyorsítás" Foreground="#aaaaaa" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Button x:Name="BoostButton1" Click="BoostButton1_Click" Width="60" Height="60" Margin="5" Background="#333337" BorderBrush="#555" BorderThickness="1">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Image Source="pack://application:,,,/Images/speedupicon1x.png" Width="40" Height="40"/>
                        </Button>

                        <Button x:Name="BoostButton2" Click="BoostButton2_Click" Width="60" Height="60" Margin="5" Background="#333337" BorderBrush="#555" BorderThickness="1">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Image Source="pack://application:,,,/Images/speedupicon2x.png" Width="40" Height="40"/>
                        </Button>

                        <Button x:Name="BoostButton3" Click="BoostButton3_Click" Width="60" Height="60" Margin="5" Background="#333337" BorderBrush="#555" BorderThickness="1">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Image Source="pack://application:,,,/Images/speedupicon3x.png" Width="40" Height="40"/>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>